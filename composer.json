{
  "name": "cgoit/contao-additional-header-logging-bundle",
  "description": "Gives you the option to use a centralized robots.txt configuration for multiple contao installations.",
  "license": "LGPL-3.0-or-later",
  "type": "contao-bundle",
  "version": "1.1.2",
  "authors": [
    {
      "name": "Carsten Götzinger",
      "homepage": "https://github.com/cgoIT"
    }
  ],
  "homepage": "https://cgo-it.de",
  "support": {
    "issues": "https://github.com/cgoIT/contao-additional-header-logging-bundle/issues",
    "source": "https://github.com/cgoIT/contao-additional-header-logging-bundle"
  },
  "require": {
    "php": "^8.2",
    "contao/core-bundle": "^5.7",
    "monolog/monolog": "^3.0",
    "symfony/config": "^7.2",
    "symfony/dependency-injection": "^7.2",
    "symfony/event-dispatcher": "^7.2",
    "symfony/http-foundation": "^7.2",
    "symfony/http-kernel": "^7.2"
  },
  "require-dev": {
    "contao/manager-plugin": "^2.0",
    "terminal42/contao-build-tools": "dev-main"
  },
  "conflict": {
    "contao/manager-plugin": "<2.0 || >=3.0"
  },
  "autoload": {
    "psr-4": {
      "Cgoit\\AdditionalHeaderLoggingBundle\\": "src/"
    }
  },
  "config": {
    "allow-plugins": {
      "contao-components/installer": true,
      "contao/manager-plugin": true,
      "php-http/discovery": true,
      "terminal42/contao-build-tools": true
    }
  },
  "extra": {
    "contao-manager-plugin": "Cgoit\\AdditionalHeaderLoggingBundle\\ContaoManager\\Plugin"
  },
  "scripts": {
    "all": [
      "@ecs",
      "@rector",
      "@phpstan",
      "@depcheck"
    ]
  }
}
